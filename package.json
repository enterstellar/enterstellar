{
  "name": "enterstellar",
  "description": "The TypeScript of Generative UI — operating system for safe, deterministic GenUI.",
  "version": "0.1.0",
  "author": "Enterstellar",
  "license": "Apache-2.0",
  "homepage": "https://enterstellar.dev",
  "repository": {
    "type": "git",
    "url": "https://github.com/enterstellar-ai/enterstellar.git"
  },
  "bugs": {
    "url": "https://github.com/enterstellar-ai/enterstellar/issues"
  },
  "keywords": [
    "ai",
    "typescript",
    "genui",
    "generative-ui",
    "enterstellar"
  ],
  "type": "module",
  "private": true,
  "packageManager": "pnpm@11.5.1",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=11.0.0"
  },
  "scripts": {
    "build": "turbo run build",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "format": "prettier --write \"packages/*/src/**/*.{ts,tsx}\" \"apps/*/src/**/*.{ts,tsx}\"",
    "format:check": "prettier --check \"packages/*/src/**/*.{ts,tsx}\" \"apps/*/src/**/*.{ts,tsx}\"",
    "syncpack:check": "syncpack lint",
    "syncpack:fix": "syncpack fix",
    "copy-licenses": "node scripts/copy-licenses.mjs",
    "changeset": "changeset",
    "changeset:version": "changeset version",
    "changeset:publish": "turbo run build && changeset publish",
    "prepare": "husky",
    "env": "dotenvx run --"
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.5.2",
    "@changesets/cli": "^2.29.8",
    "@commitlint/cli": "^20.4.2",
    "@commitlint/config-conventional": "^20.4.2",
    "@dotenvx/dotenvx": "^1.52.0",
    "@typescript-eslint/eslint-plugin": "^8.56.0",
    "@typescript-eslint/parser": "^8.56.0",
    "eslint": "^10.0.0",
    "eslint-plugin-unused-imports": "^4.4.1",
    "globals": "^17.3.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "prettier": "^3.8.1",
    "syncpack": "^15.3.1",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "turbo": "^2.9.16",
    "typescript": "^5.9.3",
    "vitest": "^4.1.8",
    "zod": "^4.3.6"
  }
}
