{
  "name": "@enterstellar-ai/global-index",
  "description": "Federated registry discovery and search — the npm for ComponentContracts.",
  "author": "Enterstellar",
  "version": "0.0.0",
  "type": "module",
  "private": false,
  "license": "Apache-2.0",
  "publishConfig": {
    "access": "public"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "peerDependencies": {
    "@enterstellar-ai/types": "workspace:*",
    "@enterstellar-ai/cloud": "workspace:*",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@enterstellar-ai/types": "workspace:*",
    "@enterstellar-ai/cloud": "workspace:*",
    "zod": "^4.3.6"
  }
}
