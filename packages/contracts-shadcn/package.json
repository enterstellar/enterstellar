{
  "name": "@enterstellar-ai/contracts-shadcn",
  "description": "shadcn/ui component contracts — pre-built ComponentContracts for shadcn/ui components.",
  "version": "0.1.0",
  "author": "Enterstellar",
  "license": "Apache-2.0",
  "homepage": "https://enterstellar.dev",
  "repository": {
    "type": "git",
    "url": "https://github.com/enterstellar-ai/enterstellar.git",
    "directory": "packages/contracts-shadcn"
  },
  "bugs": {
    "url": "https://github.com/enterstellar-ai/enterstellar/issues"
  },
  "keywords": [
    "shadcn",
    "contracts",
    "components",
    "generative-ui",
    "enterstellar"
  ],
  "type": "module",
  "private": false,
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "LICENSE",
    "NOTICE",
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "peerDependencies": {
    "@enterstellar-ai/react": "workspace:*",
    "@enterstellar-ai/registry": "workspace:*",
    "@enterstellar-ai/types": "workspace:*",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@enterstellar-ai/react": "workspace:*",
    "@enterstellar-ai/registry": "workspace:*",
    "@enterstellar-ai/types": "workspace:*",
    "@types/react": "^19.2.14",
    "zod": "^4.3.6"
  }
}
