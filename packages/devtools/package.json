{
  "name": "@enterstellar-ai/devtools",
  "description": "Embedded DevTools panel — trace inspector, component inspector, cache dashboard, replay.",
  "version": "0.1.0",
  "author": "Enterstellar",
  "license": "Apache-2.0",
  "homepage": "https://enterstellar.dev",
  "repository": {
    "type": "git",
    "url": "https://github.com/enterstellar-ai/enterstellar.git",
    "directory": "packages/devtools"
  },
  "bugs": {
    "url": "https://github.com/enterstellar-ai/enterstellar/issues"
  },
  "keywords": [
    "devtools",
    "debugging",
    "trace",
    "generative-ui",
    "enterstellar"
  ],
  "type": "module",
  "private": false,
  "sideEffects": true,
  "publishConfig": {
    "access": "public"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "LICENSE",
    "NOTICE",
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "peerDependencies": {
    "@enterstellar-ai/types": "workspace:*",
    "@enterstellar-ai/react": "workspace:*",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "@enterstellar-ai/types": "workspace:*",
    "@enterstellar-ai/react": "workspace:*",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "@testing-library/react": "^16.3.2",
    "@testing-library/jest-dom": "^6.9.1",
    "jsdom": "^28.1.0"
  }
}
