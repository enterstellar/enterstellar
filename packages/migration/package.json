{
  "name": "@enterstellar-ai/migration",
  "description": "Component migration pipeline — AST extraction, LLM enrichment, and contract assembly.",
  "version": "1.0.0",
  "author": "Enterstellar",
  "license": "Apache-2.0",
  "homepage": "https://enterstellar.dev",
  "repository": {
    "type": "git",
    "url": "https://github.com/enterstellar-ai/enterstellar.git",
    "directory": "packages/migration"
  },
  "bugs": {
    "url": "https://github.com/enterstellar-ai/enterstellar/issues"
  },
  "keywords": [
    "migration",
    "ast",
    "codemod",
    "generative-ui",
    "enterstellar"
  ],
  "type": "module",
  "private": false,
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "LICENSE",
    "NOTICE",
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "ts-morph": "^28.0.0"
  },
  "peerDependencies": {
    "@enterstellar-ai/types": "workspace:*",
    "@enterstellar-ai/compiler": "workspace:*",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@enterstellar-ai/types": "workspace:*",
    "@enterstellar-ai/compiler": "workspace:*",
    "@types/node": "^25.5.0",
    "zod": "^4.3.6"
  }
}
