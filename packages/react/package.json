{
  "name": "@enterstellar-ai/react",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "React integration — Provider, Zone, lifecycle management, cache, adapters, and hooks.",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@enterstellar-ai/types": "workspace:*",
    "@enterstellar-ai/registry": "workspace:*",
    "@enterstellar-ai/compiler": "workspace:*",
    "@enterstellar-ai/state": "workspace:*",
    "@enterstellar-ai/telemetry": "workspace:*",
    "@enterstellar-ai/connection": "workspace:*",
    "@enterstellar-ai/cache": "workspace:*",
    "@enterstellar-ai/lifecycle": "workspace:*",
    "@enterstellar-ai/adapters": "workspace:*"
  },
  "peerDependencies": {
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "@testing-library/react": "^16.3.2",
    "@testing-library/jest-dom": "^6.9.1",
    "jsdom": "^28.1.0",
    "zod": "^4.3.6"
  }
}
