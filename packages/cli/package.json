{
  "name": "@enterstellar-ai/cli",
  "description": "Enterstellar CLI — interactive project scaffolding (enterstellar init) and component generation (enterstellar add component).",
  "author": "Enterstellar",
  "version": "0.0.0",
  "type": "module",
  "private": false,
  "license": "Apache-2.0",
  "publishConfig": {
    "access": "public"
  },
  "bin": {
    "enterstellar": "./dist/bin.js",
    "ens": "./dist/bin.js",
    "create-enterstellar-app": "./dist/create-enterstellar-app.js"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@enterstellar-ai/migration": "workspace:*",
    "@clack/prompts": "^0.9.1",
    "fast-glob": "^3.3.3",
    "picocolors": "^1.1.1"
  },
  "peerDependencies": {
    "@enterstellar-ai/types": "workspace:*",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@enterstellar-ai/types": "workspace:*",
    "@types/node": "^25.3.0"
  }
}
