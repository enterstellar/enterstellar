{
  "name": "@enterstellar-ai/cli",
  "description": "Enterstellar CLI — project scaffolding (enterstellar init) and component generation.",
  "version": "0.1.0",
  "author": "Enterstellar",
  "license": "Apache-2.0",
  "homepage": "https://enterstellar.dev",
  "repository": {
    "type": "git",
    "url": "https://github.com/enterstellar-ai/enterstellar.git",
    "directory": "packages/cli"
  },
  "bugs": {
    "url": "https://github.com/enterstellar-ai/enterstellar/issues"
  },
  "keywords": [
    "cli",
    "scaffolding",
    "create-app",
    "generative-ui",
    "enterstellar"
  ],
  "type": "module",
  "private": false,
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  },
  "bin": {
    "enterstellar": "./dist/bin.js",
    "ens": "./dist/bin.js",
    "create-enterstellar-app": "./dist/create-enterstellar-app.js"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "LICENSE",
    "NOTICE",
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@enterstellar-ai/migration": "workspace:*",
    "@clack/prompts": "^0.9.1",
    "fast-glob": "^3.3.3",
    "picocolors": "^1.1.1"
  },
  "peerDependencies": {
    "@enterstellar-ai/types": "workspace:*",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@enterstellar-ai/types": "workspace:*",
    "@types/node": "^25.5.0"
  }
}
