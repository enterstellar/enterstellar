{
  "name": "@enterstellar-ai/contract-protocol",
  "description": "JSON Schema protocol spec — language-agnostic definitions for non-TypeScript renderers.",
  "version": "0.0.0",
  "author": "Enterstellar",
  "license": "Apache-2.0",
  "homepage": "https://enterstellar.dev",
  "repository": {
    "type": "git",
    "url": "https://github.com/enterstellar-ai/enterstellar.git",
    "directory": "packages/contract-protocol"
  },
  "bugs": {
    "url": "https://github.com/enterstellar-ai/enterstellar/issues"
  },
  "keywords": [
    "json-schema",
    "protocol",
    "spec",
    "generative-ui",
    "enterstellar"
  ],
  "type": "module",
  "private": false,
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  },
  "bin": {
    "enterstellar-protocol-validate": "./bin/validate.ts"
  },
  "files": [
    "LICENSE",
    "NOTICE",
    "schemas",
    "examples",
    "conformance",
    "bin",
    "PROTOCOL_VERSION.md"
  ],
  "scripts": {
    "generate": "tsx scripts/generate.ts",
    "validate": "tsx bin/validate.ts",
    "typecheck": "tsc --noEmit",
    "lint": "eslint __tests__/",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "@enterstellar-ai/types": "workspace:*",
    "@types/node": "^25.3.0",
    "ajv": "^8.18.0",
    "tsx": "^4.21.0",
    "vitest": "latest",
    "zod": "^4.3.6"
  }
}
