{
  "name": "@enterstellar-ai/adapter-supabase",
  "description": "Supabase adapter — Auth and Data adapter implementations for Supabase.",
  "version": "0.0.0",
  "author": "Enterstellar",
  "license": "Apache-2.0",
  "homepage": "https://enterstellar.dev",
  "repository": {
    "type": "git",
    "url": "https://github.com/enterstellar-ai/enterstellar.git",
    "directory": "packages/adapter-supabase"
  },
  "bugs": {
    "url": "https://github.com/enterstellar-ai/enterstellar/issues"
  },
  "keywords": [
    "supabase",
    "adapter",
    "auth",
    "data",
    "generative-ui",
    "enterstellar"
  ],
  "type": "module",
  "private": false,
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "LICENSE",
    "NOTICE",
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "peerDependencies": {
    "@enterstellar-ai/types": "workspace:*",
    "@supabase/supabase-js": "^2.99.0"
  },
  "devDependencies": {
    "@enterstellar-ai/types": "workspace:*",
    "@enterstellar-ai/adapters": "workspace:*",
    "@supabase/supabase-js": "^2.99.0"
  }
}
