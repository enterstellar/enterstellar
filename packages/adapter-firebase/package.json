{
  "name": "@enterstellar-ai/adapter-firebase",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Firebase adapter — Auth + Data adapters for Firebase (Bible §4.15, P1 priority).",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "peerDependencies": {
    "@enterstellar-ai/types": "workspace:*",
    "firebase": "^12.10.0"
  },
  "devDependencies": {
    "@enterstellar-ai/types": "workspace:*",
    "@enterstellar-ai/adapters": "workspace:*",
    "firebase": "^12.10.0"
  }
}
