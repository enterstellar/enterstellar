{
  "name": "@enterstellar-ai/telemetry",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "ForgeSignal collection, queuing, and upload. Zero-PII telemetry for the Forge.",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "peerDependencies": {
    "@enterstellar-ai/types": "workspace:*"
  },
  "devDependencies": {
    "@enterstellar-ai/types": "workspace:*",
    "fake-indexeddb": "^6.2.5"
  }
}
