# Enterstellar Monorepo pnpm Configuration
# Strict peer dependency enforcement for production-grade reliability.

# Configure fetch timeout to 5 minutes for large package installations.
fetch-timeout=300000

# Hoist ESLint, Prettier, and styling tools for editor/tooling integration.
public-hoist-pattern[]=*eslint*
public-hoist-pattern[]=*prettier*
public-hoist-pattern[]=*commitlint*
