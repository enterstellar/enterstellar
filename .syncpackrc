  "sortAz": ["contributors", "dependencies", "devDependencies", "keywords", "peerDependencies"],
  "sortFirst": ["name", "description", "version", "private", "type", "main", "module", "types", "exports"],
  "source": ["package.json", "packages/*/package.json", "apps/*/package.json", "examples/*/package.json"],
