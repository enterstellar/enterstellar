{
  "name": "@enterstellar-ai/examples-full-app",
  "description": "Enterstellar full-app example — complete Next.js app with all Enterstellar features.",
  "author": "Enterstellar",
  "version": "0.0.0",
  "type": "module",
  "private": true,
  "license": "Apache-2.0",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
