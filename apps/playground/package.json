{
  "name": "playground",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Enterstellar Playground Presence.",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "deploy": "opennextjs-cloudflare build && opennextjs-cloudflare deploy",
    "upload": "opennextjs-cloudflare build && opennextjs-cloudflare upload",
    "preview": "opennextjs-cloudflare build && opennextjs-cloudflare preview",
    "cf-typegen": "wrangler types --env-interface CloudflareEnv ./cloudflare-env.d.ts"
  },
  "dependencies": {
    "@opennextjs/cloudflare": "^1.18.0",
    "@enterstellar-ai/cache": "workspace:*",
    "@enterstellar-ai/devtools": "workspace:*",
    "@enterstellar-ai/react": "workspace:*",
    "@enterstellar-ai/registry": "workspace:*",
    "@enterstellar-ai/types": "workspace:*",
    "@ai-sdk/groq": "^3.0.32",
    "@ai-sdk/google": "^3.0.55",
    "ai": "^6.0.143",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.7.0",
    "framer-motion": "^12.38.0",
    "motion": "^12.38.0",
    "next": "16.2.1",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "tailwind-merge": "^3.5.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.2",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "babel-plugin-react-compiler": "1.0.0",
    "tailwindcss": "^4.2.2",
    "typescript": "^5.9.3",
    "wrangler": "^4.77.0"
  }
}
