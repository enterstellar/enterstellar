/**
 * Enterstellar Playground — Wrangler Configuration
 *
 * Cloudflare Workers deployment config for the Enterstellar Playground marketing site.
 * Deployed via @opennextjs/cloudflare adapter (WP3).
 *
 * Route: enterstellar.dev/*  (catch-all, lowest priority — WP5)
 * The catch-all route MUST be deployed last. More specific routes
 * (enterstellar.dev/docs/*, enterstellar.dev/blog/*) take priority.
 *
 * @see archive/CORE/enterstellar-web-implementation-plan.md §4.5 — playground spec
 * @see archive/CORE/enterstellar-web-presence-appendix.md — WP3, WP5
 */
{
	"$schema": "node_modules/wrangler/config-schema.json",
	"name": "playground",
	"main": ".open-next/worker.js",
	"compatibility_date": "2025-09-27",
	"compatibility_flags": [
		"nodejs_compat",
		"global_fetch_strictly_public"
	],
	"assets": {
		"binding": "ASSETS",
		"directory": ".open-next/assets"
	},
	"images": {
		"binding": "IMAGES"
	},
	"services": [
		{
			"binding": "WORKER_SELF_REFERENCE",
			"service": "playground"
		}
	],
	"observability": {
		"enabled": true
	},
	"upload_source_maps": true
}
