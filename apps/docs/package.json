{
  "name": "@enterstellar-ai/docs",
  "description": "Official documentation site — architecture guides, API reference, and interactive examples.",
  "version": "0.0.0",
  "author": "Enterstellar",
  "license": "Apache-2.0",
  "homepage": "https://enterstellar.dev",
  "repository": {
    "type": "git",
    "url": "https://github.com/enterstellar-ai/enterstellar.git",
    "directory": "apps/docs"
  },
  "bugs": {
    "url": "https://github.com/enterstellar-ai/enterstellar/issues"
  },
  "keywords": [
    "docs",
    "documentation",
    "generative-ui",
    "enterstellar"
  ],
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "lint:links": "LINT=1 fumadocs-mdx && node --import tsx --import ./scripts/register-mdx.js scripts/lint.ts",
    "typecheck": "fumadocs-mdx && next typegen && tsc --noEmit",
    "postinstall": "fumadocs-mdx",
    "cf-build": "opennextjs-cloudflare build",
    "deploy": "pnpm run cf-build && opennextjs-cloudflare deploy",
    "upload": "pnpm run cf-build && opennextjs-cloudflare upload",
    "preview": "pnpm run cf-build && opennextjs-cloudflare preview",
    "cf-typegen": "wrangler types --env-interface CloudflareEnv ./cloudflare-env.d.ts"
  },
  "dependencies": {
    "@ai-sdk/google": "^3.0.55",
    "@ai-sdk/google-vertex": "^4.0.99",
    "@ai-sdk/groq": "^3.0.32",
    "@ai-sdk/react": "^3.0.145",
    "@opennextjs/cloudflare": "^1.18.0",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-hover-card": "^1.1.15",
    "@radix-ui/react-presence": "^1.1.5",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@orama/orama": "^3.1.18",
    "@fumadocs/story": "^0.0.11",
    "@takumi-rs/image-response": "^0.73.1",
    "ai": "^6.0.143",
    "class-variance-authority": "^0.7.1",
    "flexsearch": "^0.8.212",
    "fumadocs-core": "16.7.7",
    "fumadocs-docgen": "3.0.8",
    "fumadocs-mdx": "14.2.11",
    "fumadocs-twoslash": "3.1.15",
    "fumadocs-typescript": "5.2.1",
    "fumadocs-ui": "16.7.7",
    "hast-util-to-jsx-runtime": "^2.3.6",
    "katex": "0.16.43",
    "lucide-react": "^1.7.0",
    "mermaid": "^11.13.0",
    "next": "16.2.1",
    "next-themes": "^0.4.6",
    "octokit": "^5.0.5",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-force-graph-2d": "^1.29.1",
    "d3-force": "^3.0.0",
    "rehype-katex": "^7.0.1",
    "remark": "^15.0.1",
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0",
    "remark-rehype": "^11.1.2",
    "shiki": "^4.0.2",
    "tailwind-merge": "^3.5.0",
    "unist-util-visit": "^5.1.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@fumadocs/cli": "^1.3.4",
    "@tailwindcss/postcss": "^4.2.2",
    "@types/d3-force": "^3.0.10",
    "@types/hast": "^3.0.4",
    "@types/mdast": "^4.0.4",
    "@types/mdx": "^2.0.13",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@next/bundle-analyzer": "^16.2.2",
    "next-validate-link": "^1.6.4",
    "babel-plugin-react-compiler": "1.0.0",
    "tailwindcss": "^4.2.2",
    "tailwindcss-animate": "^1.0.7",
    "typescript": "^5.9.3",
    "tsx": "^4.21.0",
    "unified": "^11.0.5",
    "wrangler": "^4.77.0"
  }
}
